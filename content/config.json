        { "name": "flagName", "value": "{captured_value_from_regex_1}" },
        { "name": "value", "value": "{captured_value_from_regex_2}" }
      ],
      "actor": "DM",
      "command": "setFlag",
      "replace": true
    },
    {
      "id": "random_item_table_tag",
      "type": "gameMechanic",

{
  "tags": [
    {
      "id": "choice_line",
      "type": "dynamicText",
      "regex": "^CHOICE\\|([^|]+)\\|([^|]+)\\|(.+)$",
      "replacement": null,
      "parameters": [
        { "name": "sceneId", "value": "{captured_value_from_regex_1}" },
        { "name": "progressiveId", "value": "{captured_value_from_regex_2}" },
        { "name": "translatedText", "value": "{captured_value_from_regex_3}" }
      ],
      "actor": "DM",
      "command": "updateChoiceText",
      "replace": true
    },
    {
      "id": "discipline_line",
      "type": "dynamicText",
      "regex": "^DISCIPLINE\\|([^|]+)\\|(.+)$",
      "replacement": null,
      "parameters": [
        { "name": "id", "value": "{captured_value_from_regex_1}" },
        { "name": "translatedText", "value": "{captured_value_from_regex_2}" }
      ],
      "actor": "DM",
      "command": "updateDisciplineChoiceText",
      "replace": true
    },
    {
      "id": "start_adventure_prompt",
      "type": "promptDescription",
      "regex": "\\{start_adventure_prompt\\}",
      "replacement": null,
      "parameters": [
        {
          "name": "baseText",
          "value": "You are the narrator of an interactive gamebook. Your task is to enrich and translate a scene for the player."
        },
        {
          "name": "previousSceneText",
          "value": "[THE STORY SO FAR]\n{previous_scene_text}"
        },
        {
          "name": "sceneText",
          "value": "[CURRENT SCENE — source text in {source_language}]\n{scene_narrative_text}"
        },
        {
          "name": "continuationsText",
          "value": "[POSSIBLE CONTINUATIONS — for consistency only, do NOT reveal them]\n{continuations_text}"
        },
        {
          "name": "choicesText",
          "value": "[CHOICES TO TRANSLATE]\n{choices_text}"
        },
        {
          "name": "constraintText",
          "value": "Follow these instructions EXACTLY:\n1. Rewrite the CURRENT SCENE text in {user_language}, enriching it with details consistent with the '{genre}' genre and this tone: {tone_hints}. Keep all facts, characters, items and events of the source text unchanged. Do NOT invent new events, items or characters.\n2. Your answer must start DIRECTLY with the scene text. Do NOT repeat the story so far. Do NOT anticipate the continuations.\n3. Character speech goes between single quotes ' ', never between \".\n4. Never use the | character in the narrative text.\n5. NEVER generate game mechanics tags such as <ADD_ITEM> or <STAT_MOD>.\n6. The player character is {player_gender}: use the correct grammatical agreement."
        },
        {
          "name": "outputFormatText",
          "value": "After the scene text, write the separator: --- TAGS ---\nBelow the separator, one line per choice, exactly in this format:\nCHOICE|scene_id|progressive|translated text\nDISCIPLINE|discipline_id|translated text"
        },
        {
          "name": "enemyFormatText",
          "value": "ENEMY|translated enemy name"
        },
        {
          "name": "closingText",
          "value": "NARRATOR (in {user_language}, tone: {tone_hints}):"
        }
      ],
      "actor": "ANY",
      "command": null,
      "replace": false
    },
    {
      "id": "add_item_tag",
      "type": "gameMechanic",
      "regex": "<addItem\\s+itemType=\\\"([^\\\"]*)\\\"\\s+itemName=\\\"([^\\\"]*)\\\"\\s+quantity=\\\"(\\d+)\\\"(?:\\s+modifier=\\\"([^\\\"]*)\\\")?(?:\\s+notes=\\\"([^\\\"]*)\\\")?\\s*\\/>",
      "parameters": [
        { "name": "itemType", "value": "{captured_value_from_regex_1}" },
        { "name": "itemName", "value": "{captured_value_from_regex_2}" },
        { "name": "quantity", "value": "{captured_value_from_regex_3}" },
        { "name": "modifier", "value": "{captured_value_from_regex_4}" },
        { "name": "notes", "value": "{captured_value_from_regex_5}" }
      ],
      "actor": "DM",
      "command": "addItem",
      "replace": true
    },
    {
      "id": "remove_item_tag",
      "type": "gameMechanic",
      "regex": "<removeItem\\s+itemName=\\\"([^\\\"]*)\\\"\\s+quantity=\\\"(\\d+)\\\"\\s*\\/>",
      "parameters": [
        { "name": "itemName", "value": "{captured_value_from_regex_1}" },
        { "name": "quantity", "value": "{captured_value_from_regex_2}" }
      ],
      "actor": "DM",
      "command": "removeItem",
      "replace": true,
      "status": "TO_IMPLEMENT"
    },
    {
      "id": "require_action_tag",
      "type": "gameMechanic",
      "regex": "<requireAction\\s+action=\\\"([^\\\"]*)\\\"\\s+penaltyStat=\\\"([^\\\"]*)\\\"\\s+penaltyValue=\\\"([+-]?\\d+)\\\"\\s*\\/>",
      "parameters": [
        { "name": "action", "value": "{captured_value_from_regex_1}" },
        { "name": "penaltyStat", "value": "{captured_value_from_regex_2}" },
        { "name": "penaltyValue", "value": "{captured_value_from_regex_3}" }

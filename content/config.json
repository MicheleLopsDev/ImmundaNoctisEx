      "command": "checkStatAndJump",
      "replace": true
    },
    {
      "id": "random_choice_table_tag",
      "type": "gameMechanic",
      "regex": "<randomChoiceTable\\s+outcomes=\\\"(\\[.*?\\])\\\"\\s*\\/>",
      "parameters": [
        { "name": "outcomes", "value": "{captured_value_from_regex_1}" }
      ],

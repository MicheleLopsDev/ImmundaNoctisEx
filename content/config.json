    {
      "id": "stat_mod_tag",
      "type": "gameMechanic",
      "regex": "<statMod\\s+statName=\\\"([^\\\"]*)\\\"\\s+amount=\\\"([+-]?\\d+|-?FULL)\\\"\\s*\\/>",

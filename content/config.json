    {
      "id": "if_item_choice_tag",
      "type": "gameMechanic",
      "regex": "<ifItem\\s+itemName=\\\"([^\\\"]*)\\\"(?:\\s+quantity=\\\"(\\d+)\\\")?\\s+operator=\\\"([^\\\"]*)\\\"\\s+nextSceneId_TRUE=\\\"([^\\\"]*)\\\"(?:\\s+nextSceneId_FALSE=\\\"([^\\\"]*)\\\")?\\s*/>",
      "parameters": [
        { "name": "itemName", "value": "{captured_value_from_regex_1}" },
        { "name": "quantity", "value": "{captured_value_from_regex_2}" },
        { "name": "operator", "value": "{captured_value_from_regex_3}" },
        { "name": "nextSceneId_TRUE", "value": "{captured_value_from_regex_4}" },

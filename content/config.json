      "regex": "<updateGlobalVar\\s+varName=\\\"([^\\\"]*)\\\"\\s+value=\\\"([+-]?\\d+)\\\"\\s+operation=\\\"([^\\\"]*)\\\"\\s*\\/>",
      "parameters": [

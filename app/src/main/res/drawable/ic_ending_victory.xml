<!--
  Finale di VITTORIA: sole che sorge sull'orizzonte (richiesta Michele
  20/07/2026, "caso vittoria un sole nascente").

  Come il teschio della sconfitta: vettoriale scritto a mano, pesa byte
  e scala ovunque. Qui il colore NON si tinge col tema — l'oro è la
  convenzione del progetto per il Kai (cerchio d'oro su chi parla,
  medaglia del grado), e un sole grigio non sarebbe un premio.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="96dp"
    android:height="96dp"
    android:viewportWidth="96"
    android:viewportHeight="96">

    <!-- Raggi: piu' lunghi in alto, accorciati verso l'orizzonte, cosi'
         il sole sembra sorgere invece che stare fermo in cielo -->
    <group>
        <path
            android:pathData="M48,4 L48,20"
            android:strokeColor="#FFFFD700"
            android:strokeWidth="5"
            android:strokeLineCap="round" />
        <path
            android:pathData="M25,13 L33,27"
            android:strokeColor="#FFFFD700"
            android:strokeWidth="5"
            android:strokeLineCap="round" />
        <path
            android:pathData="M71,13 L63,27"
            android:strokeColor="#FFFFD700"
            android:strokeWidth="5"
            android:strokeLineCap="round" />
        <path
            android:pathData="M9,32 L23,40"
            android:strokeColor="#FFFFD700"
            android:strokeWidth="5"
            android:strokeLineCap="round" />
        <path
            android:pathData="M87,32 L73,40"
            android:strokeColor="#FFFFD700"
            android:strokeWidth="5"
            android:strokeLineCap="round" />
        <path
            android:pathData="M4,58 L18,58"
            android:strokeColor="#FFFFD700"
            android:strokeWidth="5"
            android:strokeLineCap="round" />
        <path
            android:pathData="M92,58 L78,58"
            android:strokeColor="#FFFFD700"
            android:strokeWidth="5"
            android:strokeLineCap="round" />
    </group>

    <!-- Il disco: mezzo sole, tagliato dall'orizzonte -->
    <path
        android:fillColor="#FFFFD700"
        android:pathData="M22,70 A26,26 0 0,1 74,70 Z" />

    <!-- L'orizzonte: linea piena sotto il sole, spezzata ai lati -->

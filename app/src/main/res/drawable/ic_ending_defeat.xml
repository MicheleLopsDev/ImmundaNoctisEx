    <!-- Orbite e naso: cavità -->
    <path
        android:fillColor="#FF2E2822"
        android:pathData="M35,38m-8,0a8,9 0 1,0 16,0a8,9 0 1,0 -16,0" />
    <path
        android:fillColor="#FF2E2822"
        android:pathData="M61,38m-8,0a8,9 0 1,0 16,0a8,9 0 1,0 -16,0" />
    <path

<!--
  Finale di SCONFITTA: teschio e ossa incrociate (richiesta Michele
  20/07/2026, "caso morte un'immagine con gli scheletri").

  Vettoriale scritto a mano invece che immagine: pesa byte invece di
  megabyte (i PNG di v1 stanno sui 3-4 MB) e scala su qualunque schermo.

  Colori PROPRI e non tint dal tema: le orbite e i denti sono cavità
  scure dentro l'osso chiaro, e una tinta unica applicata dall'esterno
  le riempirebbe rendendo il teschio una macchia piena. Il contorno
  scuro serve a non farlo sparire su tema chiaro.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="96dp"
    android:height="96dp"
    android:viewportWidth="96"
    android:viewportHeight="96">

    <!-- Ossa incrociate, dietro al cranio -->
    <group>
        <path
            android:fillColor="#FFD9D2C2"
            android:strokeColor="#FF4A423A"
            android:strokeWidth="2"
            android:pathData="M24,62 L72,86 L76,78 L28,54 Z" />
        <path
            android:fillColor="#FFD9D2C2"
            android:strokeColor="#FF4A423A"
            android:strokeWidth="2"
            android:pathData="M72,62 L24,86 L20,78 L68,54 Z" />
    </group>

    <!-- Cranio: calotta tonda che si stringe sulla mascella -->
    <path
        android:fillColor="#FFE4DDCD"
